---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<li class="
  mt-2 px-2 rounded-lg border border-black/20 dark:border-white/20
  hover:bg-black/10 dark:hover:bg-white/10 hover:text-black dark:hover:text-white
">
  <a class="no-underline" href=`/tags/${tag}`>{tag}</a>
</li>

