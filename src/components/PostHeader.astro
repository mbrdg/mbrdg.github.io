---
interface Props {
  publication: Date;
  author: string;
  minutesRead: string;
}

const formatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "2-digit",
  year: "numeric"
});

const { publication, author, minutesRead } = Astro.props;
---

<hgroup class="not-prose">
  <time datetime={publication.toString()}>{formatter.format(publication)}</time>
  &bull; {minutesRead}
  <address>{author}</address>
</hgroup>
